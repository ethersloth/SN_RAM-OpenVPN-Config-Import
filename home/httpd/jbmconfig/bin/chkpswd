my $VERSION = '1.00';

# Get command line arguments, a single '-h' bypasses everything else, displays usage info and exits:

$argCnt = $#ARGV + 1;

chomp(@ARGV);

if ((0 == $argCnt) || ('-h' eq $ARGV[0]) || ('--help' eq $ARGV[0]))
  {
   print "Usage:  chkpswd <username> <password> {-h|--help} {-v|--version}";

   exit(0);
  }

if (('-v' eq $ARGV[0]) || ('--version' eq $ARGV[0]))
  {
   print $VERSION, "\n";

   exit(0);
  }

if ($argCnt < 2)
  {
   print 'Required password parameter missing', "\n";

   exit(1);
  }

my $userID   = $ARGV[0];
my $password = $ARGV[1];

my ($name, $passwd, $uid, $gid, $quota, $comment, $gcos, $dir, $shell) = getpwnam($userID);

if (defined($name))
  {
   my $cryptPswd = crypt($password, $passwd);

   if ($cryptPswd eq $passwd)
     {
      print 'Valid Password', "\n";

      exit(0);
     }
  }

print 'Invalid Password', "\n";

exit(1);


