# Read contents of /etc/stacfg directory into an array of strings for each:

opendir(DIR, "/etc/stacfg/");

my @instCfgFNamesList = sort(readdir(DIR));

closedir(DIR);


my $optCnt = 0;

foreach my $eachelement(@instCfgFNamesList)
{
    if ($eachelement =~ /\.xml$/)
    {
       print "<option value=\"/etc/stacfg/" . $eachelement . "\">" . $eachelement . "</option>\n";

       $optCnt++;
    }
}

if (0 == $optCnt)
  {
   print "<option value=\"\"></option>\n";
  }


exit(0);

