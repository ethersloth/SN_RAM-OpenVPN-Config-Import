# Read contents of /home/jbmgatew directory into an array of strings for each:
$ENV{PATH} .= ":/home/httpd/jbmconfig/bin:/sbin:/usr/bin";
my $PARSEABLE = 0;

foreach my $argnum (0 .. $#ARGV) {
   if ("--parseable" eq $ARGV[$argnum]) {
      $PARSEABLE = 1;
      next;
   }
}

opendir(DIR, "/home/jbmgatew/");

my @instCfgFNamesList = sort(readdir(DIR));

closedir(DIR);


my $optCnt = 0;

foreach my $eachelement(@instCfgFNamesList)
{
    if (($eachelement =~ /\.cfg$/) || ($eachelement =~ /\.cfg.orig$/) || ($eachelement =~ /\.xml$/))
    {
       if ($PARSEABLE)
       {
           print "/home/jbmgatew/$eachelement:$eachelement\n";
       }
       else
       {
          print "<option value=\"/home/jbmgatew/" . $eachelement . "\">" . $eachelement . "</option>\n";
       }
       $optCnt++;
    }
}

if (0 == $optCnt) {
   if ($PARSEABLE) {
      print "none:-None Selected-\|";
   }
   else {
      print "<option value=\"\"></option>\n";
   }
}

exit(0);

