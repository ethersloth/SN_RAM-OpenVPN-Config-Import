#      {
#         # Looking for lines like:
#         # 'May 25 14:34:07 pppd[24559]: Sent 0 bytes, received 0 bytes.'
#         my ($mo,$dom,$time,$proc,@msg) = split(/\s+/,$line);
#
#         if ($proc =~ /^pppd/)
#         {
#            if ($msg[0] =~ /sent/i && $msg[1] =~ /^\d+$/ && $msg[2] =~ /^bytes/i &&
#                $msg[3] =~ /received/i && $msg[4] =~ /^\d+$/ && $msg[5] =~ /^bytes/i)
#            {
