#   if (!$date)
#   {
#      my $uptime = $SYSTEM->GetSystemUptime();
#      my $timenow = time;
#
#      my ($sec,$min,$hour,$mday,$mon,$year,$wday,$yday,$isdst) = localtime(int($timenow - $uptime));
#
