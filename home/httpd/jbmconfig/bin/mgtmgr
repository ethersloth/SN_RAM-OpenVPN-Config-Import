use JBM_System;

# duct-taped management tab handler for the GAU

#Handle the following args:
# - GetGMUStatus
# - GetGMUServerAddress
# - GetGMUNextCheckIn
#
# - GetCellSignalStrength
# - GetCellConnectionStatus
# - GetCellInterfaceAddress
# - GetCellPeerAddress
# - GetCellUsage
#
# - GetDHCPServerStatus
#
# - GetEth0ConnectionStatus
# - GetEth0InterfaceAddress
#
# - GetEth1ConnectionStatus
# - GetEth1InterfaceAddress
#
# - GetFirewallServiceStatus
# - GetIptablesDump
# 
# - GetIPSECServiceStatus
# - GetIPSECTunnelStatus
# - GetIPSECTunnelStatuses
#
# - GetRootFilesystemSizeAndUsage
# - GetVarFilesystemSizeAndUsage
# - GetTmpFilesystemSizeAndUsage
#
# - GetSyslogOutput


# Write output (HTML format) to a file

my $USAGE = "$0 <command>";
my $RESULT_FILE = "/tmp/mgtmgr.out";
my $SYSTEM = JBM_System->new();

die "No args provided!\n$USAGE\n" unless (scalar(@ARGV));

if ($ARGV[0] =~ /^GetGMUStatus$/i)
{
   $SYSTEM->Syslog("GetGMUStatus()");
   # Get something from the system, and write it to the output file.
   my $enabled = $SYSTEM->IsProcessRunning('svmclient');
   WriteDataToFile($enabled ? "ENABLED" : "DISABLED");
}
elsif ($ARGV[0] =~ /^GetGMUServerAddress$/i)
{
   $SYSTEM->Syslog("GetGMUServerAddress()");
   # Get something from the system, and write it to the output file.
   my $host = $SYSTEM->GetConfigValue("/etc/jbm/svmclient.conf","JBM_SERVER_IP");
   WriteDataToFile($host);
}
elsif ($ARGV[0] =~ /^GetGMUNextCheckIn$/i)
{
   $SYSTEM->Syslog("GetGMUNextCheckIn()");
   # Get something from the system, and write it to the output file.
   my $next_checkin = $SYSTEM->IsProcessRunning('svmclient') ? "Currently Running" : "N/A";

   my (@args) = $SYSTEM->GetProcessArgs("svmclient");
   my $string = join(" ",@args);

   if ($string =~ /sleeping/)
   {
      $string =~ s/^\: sleeping for //;
      $next_checkin = "$string";
   }

   WriteDataToFile($next_checkin);
}
elsif ($ARGV[0] =~ /^GetCellSignalStrength$/i)
{
   $SYSTEM->Syslog("GetCellSignalStrength()");
   # Get something from the system, and write it to the output file.
   my $signal = $SYSTEM->GetCellSignalStrength();
   my $image  = '<img src="/images/signalq.gif" alt="Signal Strength" />'; 

   if ($signal =~ /^\-?\d+$/)
   {
      if (-1 == $signal)
      {
         $image = '<img src="/images/signalx.gif" alt="Signal Strength" />'; 
      }
      else
      {
         $image = '<img src="/images/signal' . $signal . '.gif" alt="Signal Strength" />'; 
      }
   }

   WriteDataToFile($image);
}
elsif ($ARGV[0] =~ /^GetCellConnectionStatus$/i)
{
   # Get something from the system, and write it to the output file.
   my $status = "Disabled";

   if ($SYSTEM->IsProcessRunning("pppd"))
   {
      # Status will be either connected, NOT connected
      $status = ($SYSTEM->IsPPPConnected() ? "Connected" : "Disconnected");
   }

   WriteDataToFile($status);
}
elsif ($ARGV[0] =~ /^GetCellInterfaceAddress$/i)
{
   $SYSTEM->Syslog("GetCellInterfaceAddress()");
   # Get something from the system, and write it to the output file.
   my $addr = "N/A";

   if ($SYSTEM->IsPPPConnected())
   {
      $addr = $SYSTEM->GetInterfaceAddress("ppp0");
   }

   WriteDataToFile($addr ? $addr : "Unknown");
}
elsif ($ARGV[0] =~ /^GetCellPeerAddress$/i)
{
   $SYSTEM->Syslog("GetCellPeerAddress()");
   # Get something from the system, and write it to the output file.
   my $addr = "N/A";

   if ($SYSTEM->IsPPPConnected())
   {
      $addr = $SYSTEM->GetInterfacePeerAddress("ppp0");
   }

   WriteDataToFile($addr ? $addr : "Unknown");
}
#elsif ($ARGV[0] =~ /^GetCellUsage$/i)
#{
#   $SYSTEM->Syslog("GetCellUsage()");
#   # usage - number of bytes transferred in current session (plus any from syslog)
