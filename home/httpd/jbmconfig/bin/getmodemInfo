my @modemlist = (SIM_ID, SIM_IMSI, SIM_CARRIER, MANU, MODEL, FIRMWARE_V, SKU_PRIID, ENSEN, CREG);
my @modemInfo = ();     
                             
foreach my $eachelement(@modemlist)
       {
          my $cmdStr = "cat /var/log/wireless.cardstats | grep $eachelement 2>&1 |";
          if (!open(FILE, $cmdStr))                                                                                                      
          {                                                                                                                            
             #print "Error Reading CardStats\n";
             exit;                                                
          }       
          push (@modemInfo, <FILE>);
          close(FILE);
       }

foreach my $entry (@modemInfo)
       {
         chomp($entry);
         print $entry . "::";
       }
exit(0);                                        
 
