# Get command line argument(s), if any:

foreach my $argnum (0 .. $#ARGV)
       {
        if ('-h' eq $ARGV[$argnum])
          {
           Usage();

           exit(0);
          }
       }

print "\n";

if (open(GETINTFSFILE, '/home/httpd/jbmconfig/bin/getintfs filter=eth raw=y |'))
  {
   while (<GETINTFSFILE>)
        {
         my $eth = $_;

         chomp($eth);

         if (open(ETHFILE, 'ethtool ' . $eth . ' |'))
           {
            while (<ETHFILE>)
                 {
                  print $_;
                 }

            close(ETHFILE);
           }

         print "\n";
        }

   close(GETINTFSFILE);

   exit(0);
  }


sub Usage
   {
    print "\nUsage:\n\n",

          "getintfdets\n\n",

          "Obtain detailed information pertaining to all 'eth' type interfaces in the system.\n",

          "The following parameter is supported:\n\n",

          "-h - Displays the usage information summary you are now reading.\n\n";
   }


