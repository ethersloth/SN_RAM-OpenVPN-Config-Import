#!/usr/bin/perl -w
# ©2015 Red Lion Controls, Inc. All rights reserved. Red Lion, the Red Lion logo and Sixnet are registered trademarks of Red Lion Controls, Inc. All other company and product names are trademarks of their respective owners.


# Get command line argument(s), if any:


# Get command line arguments, a single '-h' bypasses everything else, display usage info and exit:

$argCnt = $#ARGV + 1;

chomp(@ARGV);

if ((0 == $argCnt) || ($ARGV[0] =~ /\-h/))
{
    print "Usage:  DelOrphEthAliases eth0|eth1|eth2\n";

    exit(1);
}


# Get total number of ethernet interface alias entries from the Master Configuration file:

my $intfName = $ARGV[0];

my $confAliasesCnt = 0;

if (
    open(
        FILE,
        "/home/httpd/jbmconfig/bin/xpeval -s --in=/home/httpd/jbmconfig/conf/config.xml " .
        "--xpath=\"/GAUCfg/" . $intfName . "/aliass/NumberOfaliass/text()\" |"
        )
    )
{
    while (<FILE>)
    {
        $confAliasesCnt = $_;

        chomp($confAliasesCnt);
    }

    close(FILE);
}


# Get a list of alias IDs from the Master Configuration file:

my @cfgAliasIDList;

for (my $aliasNdx=1; $aliasNdx<=$confAliasesCnt; $aliasNdx++)
{
    my $subIntNum = 0;

    if (
        open(
            FILE,
            "/home/httpd/jbmconfig/bin/xpeval -s --in=/home/httpd/jbmconfig/conf/config.xml --xpath=\"/GAUCfg/" .
            $intfName . "/aliass/alias[" .
            $aliasNdx . "]/subintnum/text()\" |"
            )
        )
    {
        while (<FILE>)
        {
            $subIntNum = $_;

            chomp($subIntNum);
        }

        close(FILE);
    }

    push(@cfgAliasesIDList, $subIntNum);
}



# Read contents of /etc/sysconfig/network-scripts directory into an array of strings for each:

opendir(DIR, "/etc/sysconfig/network-scripts/");

my @instAliasesList = readdir(DIR);

closedir(DIR);


# Compare the list of existing interface alias configuration files to the list of IDs obtained from the Master Configuration
# file and delete any existing file that is not referenced by the Master Configuration file:

foreach my $instAliasFName (@instAliasesList)
{
    my $searchStr = "ifcfg-" . $intfName . ":";

    if ($instAliasFName =~ m/^($searchStr)/i)
    {
        my $legitFile = 0;

        my $fileNdx = 0;

        foreach my $subIntNum (@cfgAliasesIDList)
        {
            if ("ifcfg-" . $intfName . ":" . $subIntNum eq $instAliasFName)
            {
                $legitFile = 1;

                $fileNdx = $subIntNum;

                last;
            }
        }

        if (0 == $legitFile)
        {
            system("ifconfig " . $intfName . ":" . $fileNdx . " down &> /dev/null");

            unlink("/etc/sysconfig/network-scripts/" . $instAliasFName);
        }
    }
}

exit(0);

