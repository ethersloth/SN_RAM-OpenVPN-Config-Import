
<profile>
 <subsystems>
  <subsystem file="/home/httpd/jbmconfig/conf/gmuclient.prf" name="gmuclient">
   <validation>
    <vstep errmsg="Invalid Enable Flag value. Must be 'y' or 'n'." name="enable" test="isyorn(/input/enable/text())" />

    <vstep errmsg="Invalid Primary Server Address. Must be IP Address of Fully qualified domain name."
             name="priservaddr"
             test="isipaddr(/input/priservaddr/text()) or isfqdn(/input/priservaddr/text())" />

    <vstep errmsg="Invalid Secondary Server Address. Must be IP Address of Fully qualified domain name."
             name="secservaddr"
             test="string-length(/input/secservaddr/text()) = 0 or
                   isipaddr(/input/secservaddr/text())          or
                   isfqdn(/input/secservaddr/text())" />

    <vstep errmsg="Invalid Address Mode. Must be either 'Primary Only', 'Secondary Only', 'Both' or 'Secondary when Primary Unavailable'"
             name="useaddr"
             test="/input/useaddr/text() = 'none'   or
                   /input/useaddr/text() = 'secondaryonly'   or
                   /input/useaddr/text() = 'both'  or
                   /input/useaddr/text() = 'error'"   />

    <vstep errmsg="Invalid Access Interval. Must be numeric" name="ainterval" test="isnumber(/input/ainterval/text())" />

    <vstep errmsg="Invalid Error Interval. Must be numeric" name="einterval" test="isnumber(/input/einterval/text())" />

    <vstep errmsg="Invalid Access Method. Must be either 'Unsecure (http)' or 'Secure (https)'"
             name="accessmeth"
             test="/input/accessmeth/text() = 'http' or /input/accessmeth/text() = 'https'" />

    <vstep errmsg="Invalid Secure Server Port. Must be a number 1-65535."
             name="servport"
             test="isnumber(/input/secservport/text()) and /input/secservport/text() < 65536" />

    <vstep errmsg="Invalid Server Port. Must be a number 1-65535."
             name="servport"
             test="isnumber(/input/servport/text()) and /input/servport/text() < 65536" />

    <vstep errmsg="Invalid Interface. Must be either 'None' 'eth0', 'eth1', 'gre1-9' or 'ppp0'"
             name="bindintf"
             test="/input/bindintf/text() = 'None' or
                   /input/bindintf/text() = 'eth0' or
                   /input/bindintf/text() = 'eth1' or
                   /input/bindintf/text() = 'gre1' or
                   /input/bindintf/text() = 'gre2' or
                   /input/bindintf/text() = 'gre3' or
                   /input/bindintf/text() = 'gre4' or
                   /input/bindintf/text() = 'gre5' or
                   /input/bindintf/text() = 'gre6' or
                   /input/bindintf/text() = 'gre7' or
                   /input/bindintf/text() = 'gre8' or
                   /input/bindintf/text() = 'gre9' or
                   /input/bindintf/text() = 'wwan0' or
                   /input/bindintf/text() = 'ppp0'" />
   </validation>

    <vstep errmsg="Invalid Rapid Check-in interval. Must be a number 0-65535."
             name="rapidcheckin"
             test="isnumber(/input/rapidcheckin/text()) and /input/rapidcheckin/text() < 65536" />

   <configuration>
    <cstep errmsg="Cannot save Enable to configuration file"             name="enable"      path="/GAUCfg/gmuclient/enable"      />
    <cstep errmsg="Cannot save Primary Address to configuration file"    name="priservaddr" path="/GAUCfg/gmuclient/priservaddr" />
    <cstep errmsg="Cannot save Secondary Address to configuration file"  name="secservaddr" path="/GAUCfg/gmuclient/secservaddr" />
    <cstep errmsg="Cannot save Address mode to configuration file"       name="useaddr"     path="/GAUCfg/gmuclient/useaddr"     />
    <cstep errmsg="Cannot save Access Interval to configuration file"    name="ainterval"   path="/GAUCfg/gmuclient/ainterval"   />
    <cstep errmsg="Cannot save Error Interval to configuration file"     name="einterval"   path="/GAUCfg/gmuclient/einterval"   />
    <cstep errmsg="Cannot save Access Method to configuration file"      name="accessmeth"  path="/GAUCfg/gmuclient/accessmeth"  />
    <cstep errmsg="Cannot save Secure Server Port to configuration file" name="secservport" path="/GAUCfg/gmuclient/secservport" />
    <cstep errmsg="Cannot save Server Port to configuration file"        name="servport"    path="/GAUCfg/gmuclient/servport"    />
    <cstep errmsg="Cannot save Interface to configuration file"          name="bindintf"    path="/GAUCfg/gmuclient/bindintf"    />
    <cstep errmsg="Cannot save Rapid Check-in interval"          name="rapidcheckin"    path="/GAUCfg/gmuclient/rapidcheckin"    />
   </configuration>

   <action name="Dummy" successmsg="SVM settings stored in xml."></action>

   <action name="Save" successmsg="SVM Client settings saved.">

