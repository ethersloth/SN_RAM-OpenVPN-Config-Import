                    <arg expr="'manual control register low=-1'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'manual control register=-1'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'opt adv=1'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'opt ws=0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('station name=', /GAUCfg/modbus/localname/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('station number=', /GAUCfg/modbus/localStationNum/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="'watchdog action=0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'watchdog alarm reg=0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'watchdog time sec=5'" source="config" />
                    <arg expr="\n" />
