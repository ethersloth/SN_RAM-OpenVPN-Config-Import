
<profile>
    <subsystems>

        <!-- Advanced -> DNP3 All Screens Settings Section -->

        <subsystem file="/home/httpd/jbmconfig/conf/dnp3.prf" name="dnp3">
            <validation>
            </validation>

            <configuration>
              <cstep errmsg="Unable to save DNP3 Enable option to system configuration file."
                       name="enable"
                       path="/GAUCfg/dnp3/enable" />

              <cstep errmsg="Unable to save DNP3 Common IP Address to system configuration file."
