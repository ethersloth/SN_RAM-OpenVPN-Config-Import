                    <arg expr="\n" />
                    <arg expr="'statusReg=-1'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'typeReg=-1'" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                    <arg expr="'[redundancy settings]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'Other_Active=4'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'Other_Heartbeat=3'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'Other_Status=5'" source="config" />
