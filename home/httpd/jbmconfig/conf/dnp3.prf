                    <arg expr="concat('UnsolQueueThreshold=', /GAUCfg/dnp3/eventrptquethreshold/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('MaxUnsolEvents=', /GAUCfg/dnp3/maxunsolevents/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('throwOldestEventOnBufferFull=', /GAUCfg/dnp3/throwOldestEventOnBufferFull/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('EventDetectRate=', /GAUCfg/dnp3/eventdetrate/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('inactiveEventsInQueueTimeout=', /GAUCfg/dnp3/maxtimeevents/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                    <arg expr="'[ApplicationLayer]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('AppLayerConfirms=', /GAUCfg/dnp3/appconfchecked/text())" source="config" />
