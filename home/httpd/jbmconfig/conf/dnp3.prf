                    <arg expr="\n" />
                    <arg expr="'/dev/eth0=/etc/stacfg/porteth0.config'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'/dev/ttyS1=/etc/stacfg/portS1.config'" source="config" />
                    <arg expr="\n" />
                </astep>

                <astep abort="y" errmsg="Failed to write the ports.config configuration file to /etc/stacfg/ directory." name="SystemCommand">
