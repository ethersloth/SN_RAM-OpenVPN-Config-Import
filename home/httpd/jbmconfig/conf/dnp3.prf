                    <arg expr="concat('AppLayerConfirmRetries=', /GAUCfg/dnp3/applinkretries/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('AppLayerConfirmTimeout=', /GAUCfg/dnp3/appretrytimeout/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('AppIncrRespSEQNumAfterCONFIRM=', /GAUCfg/dnp3/seqnumconfchecked/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                    <arg expr="'[DataLinkLayer]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('ThisStationAddress= ', /GAUCfg/dnp3/stationdnpaddr/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('EnableDataLinkConf= ', /GAUCfg/dnp3/enabledataconfchecked/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('RetriesDataLinkConf= ', /GAUCfg/dnp3/datalinkretries/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('TimeOutDataLinkConf= ', /GAUCfg/dnp3/retrytimeout/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('EnableSelfAddress= ', /GAUCfg/dnp3/selfaddrchecked/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('MinResponseDelay= ', /GAUCfg/dnp3/responsedelay/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                    <arg expr="'[PhysicalLinkLayer]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('CommMode= ', /GAUCfg/dnp3/commMode/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = 'serial'"
                               expr="concat('SerialPort= /dev/', /GAUCfg/dnp3/serialport/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != 'serial'"
                               expr="'SerialPort= '" source="config" />
                    <arg expr="\n" />
                    <arg expr="'ModemDisconnectTimeout= '" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('EnableCollAvoid= ', /GAUCfg/dnp3/collisionchecked/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = 'serial'"
                               expr="concat('CollAvoidMaxRandomDelay= ', /GAUCfg/dnp3/randomdelay/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != 'serial'"
                               expr="'CollAvoidMaxRandomDelay='" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/clientchecked/text() = 'yes' and /GAUCfg/dnp3/commMode/text() = 'tcp'"
                         expr="concat('TCPDialHost= ', /GAUCfg/dnp3/hostip/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = 'udp'"
                         expr="concat('TCPDialHost= ', /GAUCfg/dnp3/hostip/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/serverchecked/text() = 'yes' and /GAUCfg/dnp3/commMode/text() = 'tcp'"
                         expr="'TCPDialHost= '" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = 'serial'"
                         expr="'TCPDialHost= '" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('TCPUDPPort= ', /GAUCfg/dnp3/port/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = 'udp'"
                         expr="concat('UDPUnsollHost= ', /GAUCfg/dnp3/udphostip/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != 'udp'"
                         expr="'UDPUnsollHost= '" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DNPUnsollDestAddr= ', /GAUCfg/dnp3/dnpaddr/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                </astep>

                <astep abort="y" errmsg="Failed to write the sxdnpdrv settings for DNPBinaryInputsCfg configuration file." name="AppendFormatted2File">
                    <arg expr="'/tmp/sxdnpdrv.ini'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'[DNPBinaryInputsCfg]'" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/binaryinput/nodnpchecked/text() = 'yes'"
                               expr="'XMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/binaryinput/nodnpchecked/text() = 'no'"
                               expr="'XMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrX=', /GAUCfg/binaryinput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultVariation=', /GAUCfg/dnp3/bininput/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultEventVariation=', /GAUCfg/dnp3/bininputchange/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                </astep>

                <astep abort="y" errmsg="Failed to write the sxdnpdrv settings for DNPBinaryOutputsCfg configuration file." name="AppendFormatted2File">
                    <arg expr="'/tmp/sxdnpdrv.ini'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'[DNPBinaryOutputsCfg]'" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/binaryoutput/nodnpchecked/text() = 'yes'"
                               expr="'YMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/binaryoutput/nodnpchecked/text() = 'no'"
                               expr="'YMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrY=', /GAUCfg/binaryoutput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultVariation=', /GAUCfg/dnp3/binoutputstatus/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultVariation=', /GAUCfg/dnp3/binoutputstatus1/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                </astep>

                <astep abort="y" errmsg="Failed to write the sxdnpdrv settings for DNPAnalogInputsCfg configuration file." name="AppendFormatted2File">
                    <arg expr="'/tmp/sxdnpdrv.ini'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'[DNPAnalogInputsCfg]'" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/analoginput/nodnpchecked/text() = 'yes'"
                               expr="'AXMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/analoginput/nodnpchecked/text() = 'no'"
                               expr="'AXMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'LowestSxRegAddrAX= 0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrAX= ', /GAUCfg/analoginput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultVariationAX=', /GAUCfg/dnp3/analoginput/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultVariationAX=', /GAUCfg/dnp3/analoginput1/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultEventVariationAX=', /GAUCfg/dnp3/analogchangeevent/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultEventVariationAX=', /GAUCfg/dnp3/analogchangeevent1/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultFrozenVariationAX=', /GAUCfg/dnp3/frozenanaloginput/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultFrozenEventVariationAX=', /GAUCfg/dnp3/frozenanalogevent/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/floatinput/nodnpchecked/text() = 'yes'"
                               expr="'FXMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/floatinput/nodnpchecked/text() = 'no'"
                               expr="'FXMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'LowestSxRegAddrFX= 0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrFX= ', /GAUCfg/floatinput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultVariationFX=', /GAUCfg/dnp3/analoginput/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultVariationFX=', /GAUCfg/dnp3/analoginput1/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultEventVariationFX=', /GAUCfg/dnp3/analogchangeevent/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultEventVariationFX=', /GAUCfg/dnp3/analogchangeevent1/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultFrozenVariationFX=', /GAUCfg/dnp3/frozenanaloginput/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultFrozenEventVariationFX=', /GAUCfg/dnp3/frozenanalogevent/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/longinput/nodnpchecked/text() = 'yes'"
                               expr="'LXMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/longinput/nodnpchecked/text() = 'no'"
                               expr="'LXMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'LowestSxRegAddrLX= 512'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrLX= ', /GAUCfg/longinput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultVariationLX=', /GAUCfg/dnp3/analoginput/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultVariationLX=', /GAUCfg/dnp3/analoginput1/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultEventVariationLX=', /GAUCfg/dnp3/analogchangeevent/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultEventVariationLX=', /GAUCfg/dnp3/analogchangeevent1/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultFrozenVariationLX=', /GAUCfg/dnp3/frozenanaloginput/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultFrozenEventVariationLX=', /GAUCfg/dnp3/frozenanalogevent/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                </astep>

                <astep abort="y" errmsg="Failed to write the sxdnpdrv settings for DNPAnalogOutputsCfg configuration file." name="AppendFormatted2File">
                    <arg expr="'/tmp/sxdnpdrv.ini'" source="config" />
                    <arg expr="\n" />
