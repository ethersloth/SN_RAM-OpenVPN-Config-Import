                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/analogoutput/nodnpchecked/text() = 'yes'"
                               expr="'AYMappedToDNP=no'" source="config" />
                    <arg dependency="/GAUCfg/analogoutput/nodnpchecked/text() = 'no'"
                               expr="'AYMappedToDNP=yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'LowestSxRegAddrAY= 0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrAY= ', /GAUCfg/analogoutput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultVariationAY=', /GAUCfg/dnp3/analogoutputstatus/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultVariationAY=', /GAUCfg/dnp3/analogoutputstatus1/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/floatoutput/nodnpchecked/text() = 'yes'"
                               expr="'FYMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/floatoutput/nodnpchecked/text() = 'no'"
                               expr="'FYMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'LowestSxRegAddrFY= 0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrFY= ', /GAUCfg/floatoutput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultVariationFY=', /GAUCfg/dnp3/analogoutputstatus/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"                                                       
                               expr="concat('DefaultVariationFY=', /GAUCfg/dnp3/analogoutputstatus1/text())" source="config" /> 
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/longoutput/nodnpchecked/text() = 'yes'"
                               expr="'LYMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/longoutput/nodnpchecked/text() = 'no'"
                               expr="'LYMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'LowestSxRegAddrLY= 0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrLY= ', /GAUCfg/longoutput/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultVariationLY=', /GAUCfg/dnp3/analogoutputstatus/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultVariationLY=', /GAUCfg/dnp3/analogoutputstatus1/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                </astep>
                
                <astep abort="y" errmsg="Failed to write the sxdnpdrv settings for DNPBinaryCountersCfg configuration file." name="AppendFormatted2File">
                    <arg expr="'/tmp/sxdnpdrv.ini'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'[DNPBinaryCountersCfg]'" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/binarycounter/nodnpchecked/text() = 'yes'"
                               expr="'LXMappedToDNP= no'" source="config" />
                    <arg dependency="/GAUCfg/binarycounter/nodnpchecked/text() = 'no'"
                               expr="'LXMappedToDNP= yes'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'LowestSxRegAddrLX= 0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('HighestSxRegAddrLX= ', /GAUCfg/binarycounter/highestreg/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultVariation=', /GAUCfg/dnp3/bincounter/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultEventVariation=', /GAUCfg/dnp3/bincounterchange/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultEventVariation=', /GAUCfg/dnp3/bincounterchange1/text())" source="config" />
                    <arg expr="\n" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() = '2'"
                               expr="concat('DefaultFrozenVariation=', /GAUCfg/dnp3/frozencounter/text())" source="config" />
                    <arg dependency="/GAUCfg/dnp3/commMode/text() != '2'"
                               expr="concat('DefaultFrozenVariation=', /GAUCfg/dnp3/frozencounter1/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="concat('DefaultFrozenEventVariation=', /GAUCfg/dnp3/frozencounterchange/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                </astep>

                <astep abort="y" errmsg="Failed to write the sxdnpdrv.ini configuration file to /etc/stacfg/ directory." name="SystemCommand">
                    <arg   expr="mv -f /tmp/sxdnpdrv.ini /etc/stacfg/sxdnpdrv.ini" />
                </astep>

                <astep  abort="n" errmsg="Failed to Build the Binary Input Object DNP Points." name="SystemCommand">          
                      <arg expr="'/home/httpd/jbmconfig/bin/dnpappend.sh'" source="config" />
                </astep>                  

                <astep abort="n" errmsg="Failed to enable sxdnpdrv service" name="SystemCommand">
                        <arg dependency="/GAUCfg/dnp3/enable/text() = 'yes'" expr="'chkconfig sxdnpdrv on'" source="config" />
                </astep>

                <astep abort="n" errmsg="Failed to disable sxdnpdrv service" name="SystemCommand">
                        <arg dependency="/GAUCfg/dnp3/enable/text() = 'no'" expr="'chkconfig sxdnpdrv off'" source="config" />
                </astep>

            </action>

            <action name="Apply" successmsg="Apply Operation Succeeded.">
                <pre subsystem="dnp3" action="Save" />

                <astep abort="n" errmsg="Failed to start the sxdnpdrv service" name="SystemCommand">
                        <arg dependency="/GAUCfg/dnp3/enable/text() = 'yes'" expr="'service sxdnpdrv restart'" source="config" />
                </astep>

                <astep abort="n" errmsg="Failed to stop the sxdnpdrv service" name="SystemCommand">
                        <arg dependency="/GAUCfg/dnp3/enable/text() = 'no'" expr="'service sxdnpdrv stop'" source="config" />
                </astep>

            </action>

        </subsystem>
    </subsystems>
</profile>
