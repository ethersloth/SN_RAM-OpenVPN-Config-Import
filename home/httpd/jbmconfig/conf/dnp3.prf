                    <arg   expr="mv -f /tmp/general.config /etc/stacfg/general.config" />
                </astep>

                <!-- Start writing the ports.config file. -->

                <astep errmsg="Failed to write the DNP3 ports.config configuration file." name="WriteFormattedFile" abort="y">
                    <arg expr="'/tmp/ports.config'" source="config" />
                    <arg expr="\n" />
                </astep>

                <astep abort="y" errmsg="Failed to write the ports settings for configuration file." name="AppendFormatted2File">
                    <arg expr="'/tmp/ports.config'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'# The [available ports] section lists the communication ports '" source="config" />
                    <arg expr="\n" />
                    <arg expr="'# available on this station. Each port is assigned to a '" source="config" />
                    <arg expr="\n" />
                    <arg expr="'# given /dev device. Do not manually edit values in this section.'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'#'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'[available ports]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'/dev/eth0=Ethernet1'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'/dev/ttyS1=RS232 Port A'" source="config" />
                    <arg expr="\n" />
