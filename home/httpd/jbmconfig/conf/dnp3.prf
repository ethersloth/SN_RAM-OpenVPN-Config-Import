                       path="/GAUCfg/dnp3/serverchecked" />

              <cstep errmsg="Unable to save DNP3 This Station DNP Address to system configuration file."
                       name="stationdnpaddr"
                       path="/GAUCfg/dnp3/stationdnpaddr" />
          
              <cstep errmsg="Unable to save DNP3 Min Response Delay to system configuration file."
                       name="responsedelay"
                       path="/GAUCfg/dnp3/responsedelay" />
          
              <cstep errmsg="Unable to save DNP3 Data Link Retries to system configuration file."
                       name="datalinkretries"
                       path="/GAUCfg/dnp3/datalinkretries" />
          
              <cstep errmsg="Unable to save DNP3 Retry Timeout to system configuration file."
                       name="retrytimeout"
                       path="/GAUCfg/dnp3/retrytimeout" />
          
              <cstep errmsg="Unable to save DNP3 Same Station Number to system configuration file."
                       name="samestationnumchecked"
                       path="/GAUCfg/dnp3/samestationnumchecked" />
          
              <cstep errmsg="Unable to save DNP3 Enable Self Address to system configuration file."
                       name="selfaddrchecked"
                       path="/GAUCfg/dnp3/selfaddrchecked" />
          
              <cstep errmsg="Unable to save DNP3 Enable Data Link Confirmation to system configuration file."
                       name="enabledataconfchecked"
                       path="/GAUCfg/dnp3/enabledataconfchecked" />

              <cstep errmsg="Unable to save DNP3 Application Link Retries to system configuration file."
                       name="applinkretries"
                       path="/GAUCfg/dnp3/applinkretries" />
          
              <cstep errmsg="Unable to save DNP3 Application Retry TimeOut to system configuration file."
                       name="appretrytimeout"
                       path="/GAUCfg/dnp3/appretrytimeout" />
          
              <cstep errmsg="Unable to save DNP3 Enable Application Layer Confirm to system configuration file."
                       name="appconfchecked"
                       path="/GAUCfg/dnp3/appconfchecked" />
          
              <cstep errmsg="Unable to save DNP3 Use Different SEQ numbers for Confirm/Response to system configuration file."
                       name="seqnumconfchecked"
                       path="/GAUCfg/dnp3/seqnumconfchecked" />

              <cstep errmsg="Unable to save DNP3 Binary Input to system configuration file."
                       name="bininput"
                       path="/GAUCfg/dnp3/bininput" />
          
              <cstep errmsg="Unable to save DNP3 Binary Input Change to system configuration file."
                       name="bininputchange"
                       path="/GAUCfg/dnp3/bininputchange" />
          
              <cstep errmsg="Unable to save DNP3 Binary Output Status to system configuration file."
                       name="binoutputstatus"
                       path="/GAUCfg/dnp3/binoutputstatus" />

              <cstep errmsg="Unable to save DNP3 Binary Output Status 1 to system configuration file."
                       name="binoutputstatus1"
                       path="/GAUCfg/dnp3/binoutputstatus1" />

              <cstep errmsg="Unable to save DNP3 Analog Input to system configuration file."
                       name="analoginput"
                       path="/GAUCfg/dnp3/analoginput" />
          
              <cstep errmsg="Unable to save DNP3 Analog Input 1 to system configuration file."
                       name="analoginput1"
                       path="/GAUCfg/dnp3/analoginput1" />
          
              <cstep errmsg="Unable to save DNP3 Frozen Analog Input to system configuration file."
                       name="frozenanaloginput"
                       path="/GAUCfg/dnp3/frozenanaloginput" />
          
              <cstep errmsg="Unable to save DNP3 Analog Change Event to system configuration file."
                       name="analogchangeevent"
                       path="/GAUCfg/dnp3/analogchangeevent" />
          
              <cstep errmsg="Unable to save DNP3 Analog Change Event 1 to system configuration file."
                       name="analogchangeevent1"
                       path="/GAUCfg/dnp3/analogchangeevent1" />
          
              <cstep errmsg="Unable to save DNP3 Frozen Analog Event to system configuration file."
                       name="frozenanalogevent"
                       path="/GAUCfg/dnp3/frozenanalogevent" />
          
              <cstep errmsg="Unable to save DNP3 Analog Output Status to system configuration file."
                       name="analogoutputstatus"
                       path="/GAUCfg/dnp3/analogoutputstatus" />
          
              <cstep errmsg="Unable to save DNP3 Analog Output Status 1 to system configuration file."
                       name="analogoutputstatus1"
                       path="/GAUCfg/dnp3/analogoutputstatus1" />
          
              <cstep errmsg="Unable to save DNP3 Binary Counter to system configuration file."
                       name="bincounter"
                       path="/GAUCfg/dnp3/bincounter" />
          
              <cstep errmsg="Unable to save DNP3 Frozen Counter to system configuration file."
                       name="frozencounter"
                       path="/GAUCfg/dnp3/frozencounter" />
          
              <cstep errmsg="Unable to save DNP3 Frozen Counter 1 to system configuration file."
                       name="frozencounter1"
                       path="/GAUCfg/dnp3/frozencounter1" />
          
              <cstep errmsg="Unable to save DNP3 Binary Counter Change to system configuration file."
                       name="bincounterchange"
                       path="/GAUCfg/dnp3/bincounterchange" />
          
              <cstep errmsg="Unable to save DNP3 Binary Counter Change 1 to system configuration file."
                       name="bincounterchange1"
                       path="/GAUCfg/dnp3/bincounterchange1" />
          
              <cstep errmsg="Unable to save DNP3 Frozen Counter Change to system configuration file."
                       name="frozencounterchange"
                       path="/GAUCfg/dnp3/frozencounterchange" />

              <cstep errmsg="Unable to save DNP3 Binary Input Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/binaryinput/exceptions"
                       type="node" />
             
              <cstep errmsg="Unable to save DNP3 Binary Output Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/binaryoutput/exceptions"
                       type="node" />

              <cstep errmsg="Unable to save DNP3 Analog Input Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/analoginput/exceptions"
                       type="node" />
             
              <cstep errmsg="Unable to save DNP3 Analog Output Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/analogoutput/exceptions"
                       type="node" />

              <cstep errmsg="Unable to save DNP3 Float Input Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/floatinput/exceptions"
                       type="node" />

              <cstep errmsg="Unable to save DNP3 Float Output Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/floatoutput/exceptions"
                       type="node" />

              <cstep errmsg="Unable to save DNP3 Long Input Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/longinput/exceptions"
                       type="node" />

              <cstep errmsg="Unable to save DNP3 Long Output Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/longoutput/exceptions"
                       type="node" />

              <cstep errmsg="Unable to save DNP3 Binary Counter Exception Class Assignments Table to system configuration file."
                       name="exceptions" path="/GAUCfg/binarycounter/exceptions"
                       type="node" />

            </configuration>

            <action name="Save" successmsg="Save Operation Succeeded.">

                <!-- Start writing the binaryinput.conf file and calling binaryinput script. -->

                <astep  abort="y"
                       errmsg="Failed to write default settings to binaryinput configuration file"
                         name="WriteFormattedFile">
            
                      <arg expr="/tmp/binaryinput.conf" />
                      <arg expr="\n" />
                      <arg expr="# This is a GAU generated file, subsequent edits are not guaranteed to be retained." />
                      <arg expr="\n" />
                      <arg expr="#configfile for /etc/stacfg/sxbinaryinput" />
                      <arg expr="\n" />
                </astep>
            
                <astep  abort="y"
                       errmsg="Failed to append global parameters to binaryinput configuration file"
                         name="AppendFormatted2File">
        
                      <arg expr="/tmp/binaryinput.conf" />
                      <arg expr="\n" />
                      <arg expr="concat('highestreg = ', /GAUCfg/binaryinput/highestreg/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('nodnpchecked = ', /GAUCfg/binaryinput/nodnpchecked/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj2class = ', /GAUCfg/binaryinput/defobj2class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('exceptCnt = ', /GAUCfg/binaryinput/exceptions/NumberOfexceptions/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="\n" />
                </astep>                  
          
                <astep      abort="y"
                       dependency="/GAUCfg/binaryinput/exceptions/NumberOfexceptions/text() != '0'"
                           errmsg="Failed to append Binaryinput Exceptions to binaryinput configuration file"
                             name="AppendFormatted2File"
                           repeat="/GAUCfg/binaryinput/exceptions/exception"
                       rptNdxName="RPT_NDX">
            
                      <arg expr="/tmp/binaryinput.conf" />
                      
                      <arg expr="concat('EXC_RULES', 'RPT_NDX', ' = {startreg => ')" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binaryinput/exceptions/exception[RPT_NDX]/startreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      
                      <arg expr="', endreg => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binaryinput/exceptions/exception[RPT_NDX]/endreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      
                      <arg expr="', exobj2class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binaryinput/exceptions/exception[RPT_NDX]/obj2class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="}"  />
                      <arg expr="\n" />
                </astep>
        
                <astep abort="y" errmsg="Failed to move binaryinput.conf" name="SystemCommand">
                      <arg expr="mv -f /tmp/binaryinput.conf /etc/stacfg/binaryinput.conf" />
                </astep>

                <!-- Start writing the analoginput.conf file and calling analoginput script. -->

                <astep  abort="y"
                       errmsg="Failed to write default settings to analoginput configuration file"
                         name="WriteFormattedFile">
            
                      <arg expr="/tmp/analoginput.conf" />
                      <arg expr="\n" />
                      <arg expr="# This is a GAU generated file, subsequent edits are not guaranteed to be retained." />
                      <arg expr="\n" />
                      <arg expr="#configfile for /etc/stacfg/sxanaloginput" />
                      <arg expr="\n" />
                </astep>
            
                <astep  abort="y"
                       errmsg="Failed to append global parameters to analoginput configuration file"
                         name="AppendFormatted2File">
        
                      <arg expr="/tmp/analoginput.conf" />
                      <arg expr="\n" />
                      <arg expr="concat('highestreg = ', /GAUCfg/analoginput/highestreg/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('nodnpchecked = ', /GAUCfg/analoginput/nodnpchecked/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('deadband = ', /GAUCfg/analoginput/deadband/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj31class = ', /GAUCfg/analoginput/defobj31class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj32class = ', /GAUCfg/analoginput/defobj32class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj33class = ', /GAUCfg/analoginput/defobj33class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('exceptCnt = ', /GAUCfg/analoginput/exceptions/NumberOfexceptions/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="\n" />
                </astep>                  
          
                <astep      abort="y"
                       dependency="/GAUCfg/analoginput/exceptions/NumberOfexceptions/text() != '0'"
                           errmsg="Failed to append Binaryinput Exceptions to analoginput configuration file"
                             name="AppendFormatted2File"
                           repeat="/GAUCfg/analoginput/exceptions/exception"
                       rptNdxName="RPT_NDX">
            
                      <arg expr="/tmp/analoginput.conf" />
                      
                      <arg expr="concat('EXC_RULES', 'RPT_NDX', ' = {startreg => ')" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/analoginput/exceptions/exception[RPT_NDX]/startreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      
                      <arg expr="', endreg => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/analoginput/exceptions/exception[RPT_NDX]/endreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
      
                      <arg expr="', exdeadband => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/analoginput/exceptions/exception[RPT_NDX]/exdeadband/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj31class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/analoginput/exceptions/exception[RPT_NDX]/obj31class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj32class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/analoginput/exceptions/exception[RPT_NDX]/obj32class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj33class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/analoginput/exceptions/exception[RPT_NDX]/obj33class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="}"  />
                      <arg expr="\n" />
                </astep>
        
                <astep abort="y" errmsg="Failed to move analoginput.conf" name="SystemCommand">
                      <arg expr="mv -f /tmp/analoginput.conf /etc/stacfg/analoginput.conf" />
                </astep>

                <!-- Start writing the floatinput.conf file and calling floatinput script. -->

                <astep  abort="y"
                       errmsg="Failed to write default settings to floatinput configuration file"
                         name="WriteFormattedFile">
            
                      <arg expr="/tmp/floatinput.conf" />
                      <arg expr="\n" />
                      <arg expr="# This is a GAU generated file, subsequent edits are not guaranteed to be retained." />
                      <arg expr="\n" />
                      <arg expr="#configfile for /etc/stacfg/sxfloatinput" />
                      <arg expr="\n" />
                </astep>
            
                <astep  abort="y"
                       errmsg="Failed to append global parameters to floatinput configuration file"
                         name="AppendFormatted2File">
        
                      <arg expr="/tmp/floatinput.conf" />
                      <arg expr="\n" />
                      <arg expr="concat('highestreg = ', /GAUCfg/floatinput/highestreg/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('nodnpchecked = ', /GAUCfg/floatinput/nodnpchecked/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('deadband = ', /GAUCfg/floatinput/deadband/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj31class = ', /GAUCfg/floatinput/defobj31class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj32class = ', /GAUCfg/floatinput/defobj32class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj33class = ', /GAUCfg/floatinput/defobj33class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('exceptCnt = ', /GAUCfg/floatinput/exceptions/NumberOfexceptions/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="\n" />
                </astep>                  
          
                <astep      abort="y"
                       dependency="/GAUCfg/floatinput/exceptions/NumberOfexceptions/text() != '0'"
                           errmsg="Failed to append Binaryinput Exceptions to floatinput configuration file"
                             name="AppendFormatted2File"
                           repeat="/GAUCfg/floatinput/exceptions/exception"
                       rptNdxName="RPT_NDX">
            
                      <arg expr="/tmp/floatinput.conf" />
                      
                      <arg expr="concat('EXC_RULES', 'RPT_NDX', ' = {startreg => ')" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/floatinput/exceptions/exception[RPT_NDX]/startreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      
                      <arg expr="', endreg => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/floatinput/exceptions/exception[RPT_NDX]/endreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
      
                      <arg expr="', exdeadband => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/floatinput/exceptions/exception[RPT_NDX]/exdeadband/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj31class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/floatinput/exceptions/exception[RPT_NDX]/obj31class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj32class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/floatinput/exceptions/exception[RPT_NDX]/obj32class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj33class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/floatinput/exceptions/exception[RPT_NDX]/obj33class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="}"  />
                      <arg expr="\n" />
                </astep>
        
                <astep abort="y" errmsg="Failed to move floatinput.conf" name="SystemCommand">
                      <arg expr="mv -f /tmp/floatinput.conf /etc/stacfg/floatinput.conf" />
                </astep>

                <!-- Start writing the longinput.conf file and calling longinput script. -->

                <astep  abort="y"
                       errmsg="Failed to write default settings to longinput configuration file"
                         name="WriteFormattedFile">
            
                      <arg expr="/tmp/longinput.conf" />
                      <arg expr="\n" />
                      <arg expr="# This is a GAU generated file, subsequent edits are not guaranteed to be retained." />
                      <arg expr="\n" />
                      <arg expr="#configfile for /etc/stacfg/sxlonginput" />
                      <arg expr="\n" />
                </astep>
            
                <astep  abort="y"
                       errmsg="Failed to append global parameters to longinput configuration file"
                         name="AppendFormatted2File">
        
                      <arg expr="/tmp/longinput.conf" />
                      <arg expr="\n" />
                      <arg expr="concat('highestreg = ', /GAUCfg/longinput/highestreg/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('nodnpchecked = ', /GAUCfg/longinput/nodnpchecked/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('deadband = ', /GAUCfg/longinput/deadband/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj31class = ', /GAUCfg/longinput/defobj31class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj32class = ', /GAUCfg/longinput/defobj32class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj33class = ', /GAUCfg/longinput/defobj33class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('exceptCnt = ', /GAUCfg/longinput/exceptions/NumberOfexceptions/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="\n" />
                </astep>                  
          
                <astep      abort="y"
                       dependency="/GAUCfg/longinput/exceptions/NumberOfexceptions/text() != '0'"
                           errmsg="Failed to append Binaryinput Exceptions to longinput configuration file"
                             name="AppendFormatted2File"
                           repeat="/GAUCfg/longinput/exceptions/exception"
                       rptNdxName="RPT_NDX">
            
                      <arg expr="/tmp/longinput.conf" />
                      
                      <arg expr="concat('EXC_RULES', 'RPT_NDX', ' = {startreg => ')" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/longinput/exceptions/exception[RPT_NDX]/startreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      
                      <arg expr="', endreg => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/longinput/exceptions/exception[RPT_NDX]/endreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
      
                      <arg expr="', exdeadband => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/longinput/exceptions/exception[RPT_NDX]/exdeadband/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj31class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/longinput/exceptions/exception[RPT_NDX]/obj31class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj32class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/longinput/exceptions/exception[RPT_NDX]/obj32class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj33class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/longinput/exceptions/exception[RPT_NDX]/obj33class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="}"  />
                      <arg expr="\n" />
                </astep>
        
                <astep abort="y" errmsg="Failed to move longinput.conf" name="SystemCommand">
                      <arg expr="mv -f /tmp/longinput.conf /etc/stacfg/longinput.conf" />
                </astep>

                <!-- Start writing the binarycounter.conf file and calling binarycounter script. -->

                <astep  abort="y"
                       errmsg="Failed to write default settings to binarycounter configuration file"
                         name="WriteFormattedFile">
            
                      <arg expr="/tmp/binarycounter.conf" />
                      <arg expr="\n" />
                      <arg expr="# This is a GAU generated file, subsequent edits are not guaranteed to be retained." />
                      <arg expr="\n" />
                      <arg expr="#configfile for /etc/stacfg/sxbinarycounter" />
                      <arg expr="\n" />
                </astep>
            
                <astep  abort="y"
                       errmsg="Failed to append global parameters to binarycounter configuration file"
                         name="AppendFormatted2File">
        
                      <arg expr="/tmp/binarycounter.conf" />
                      <arg expr="\n" />
                      <arg expr="concat('highestreg = ', /GAUCfg/binarycounter/highestreg/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('nodnpchecked = ', /GAUCfg/binarycounter/nodnpchecked/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('deadband = ', /GAUCfg/binarycounter/deadband/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj21class = ', /GAUCfg/binarycounter/defobj21class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj22class = ', /GAUCfg/binarycounter/defobj22class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('defobj23class = ', /GAUCfg/binarycounter/defobj23class/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="concat('exceptCnt = ', /GAUCfg/binarycounter/exceptions/NumberOfexceptions/text())"
                         source="config" />
                      <arg expr="\n" />
                      <arg expr="\n" />
                </astep>                  
          
                <astep      abort="y"
                       dependency="/GAUCfg/binarycounter/exceptions/NumberOfexceptions/text() != '0'"
                           errmsg="Failed to append Binaryinput Exceptions to binarycounter configuration file"
                             name="AppendFormatted2File"
                           repeat="/GAUCfg/binarycounter/exceptions/exception"
                       rptNdxName="RPT_NDX">
            
                      <arg expr="/tmp/binarycounter.conf" />
                      
                      <arg expr="concat('EXC_RULES', 'RPT_NDX', ' = {startreg => ')" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binarycounter/exceptions/exception[RPT_NDX]/startreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      
                      <arg expr="', endreg => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binarycounter/exceptions/exception[RPT_NDX]/endreg/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
      
                      <arg expr="', exdeadband => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binarycounter/exceptions/exception[RPT_NDX]/exdeadband/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj21class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binarycounter/exceptions/exception[RPT_NDX]/obj21class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj22class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binarycounter/exceptions/exception[RPT_NDX]/obj22class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="', exobj23class => '"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()"  rptNdxName="RPT_NDX" source="config" />
                      <arg expr="/GAUCfg/binarycounter/exceptions/exception[RPT_NDX]/obj23class/text()" rptNdxName="RPT_NDX" source="config" />
                      <arg expr="tick()" rptNdxName="RPT_NDX" source="config"  />
                      
                      <arg expr="}"  />
                      <arg expr="\n" />
                </astep>
        
                <astep abort="y" errmsg="Failed to move binarycounter.conf" name="SystemCommand">
                      <arg expr="mv -f /tmp/binarycounter.conf /etc/stacfg/binarycounter.conf" />
                </astep>

                <!-- Start building the Object Mapping DNP points for all I/O types. -->

                <astep  abort="n" errmsg="Failed to Build the Object Mapping DNP points for all I/O types." name="SystemCommand">          
                      <arg expr="'/home/httpd/jbmconfig/bin/dnpbuild.sh'" source="config" />
                </astep>                  

                <!-- Start writing the general.config file. -->

                <astep errmsg="Failed to write the DNP3 general.config configuration file." name="WriteFormattedFile" abort="y">
                    <arg expr="'/tmp/general.config'" source="config" />
