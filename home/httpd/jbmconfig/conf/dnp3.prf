                       path="/GAUCfg/dnp3/hostip" />
          
              <cstep errmsg="Unable to save DNP3 TCP/UDP Port Number to system configuration file."
                       name="port"
                       path="/GAUCfg/dnp3/port" />
          
              <cstep errmsg="Unable to save DNP3 UDP Host IP Address to system configuration file."
                       name="udphostip"
                       path="/GAUCfg/dnp3/udphostip" />

              <cstep errmsg="Unable to save DNP3 Serial Check Box to system configuration file."
                       name="serialchecked"
                       path="/GAUCfg/dnp3/serialchecked" />
           
              <cstep errmsg="Unable to save DNP3 Collision Check Box to system configuration file."
                       name="collisionchecked"
                       path="/GAUCfg/dnp3/collisionchecked" />
           
              <cstep errmsg="Unable to save DNP3 TCP Check Box to system configuration file."
