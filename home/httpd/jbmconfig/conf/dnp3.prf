                    <arg expr="'[aga]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'reg=02B8-C4B8-FBA'" source="config" />
                    <arg expr="\n" />
                    <arg expr="\n" />
                    <arg expr="'[dnp3]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'reg=02B5-8E0C-BF9'" source="config" />
                    <arg expr="\n" />
