                    <arg expr="concat('common subnet2=', /GAUCfg/dnp3/commsubmask2/text())" source="config" />
                    <arg expr="\n" />
                    <arg expr="'enable=0'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'heartbeat period sec=0'" source="config" />
                    <arg expr="\n" />
