                </astep>

                <astep abort="y" errmsg="Failed to write the ports settings for configuration file." name="AppendFormatted2File">
                    <arg expr="'/tmp/general.config'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'# This file contains station configuration settings.'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'#'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'[station settings]'" source="config" />
                    <arg expr="\n" />
                    <arg expr="'Freeze enable=0'" source="config" />
