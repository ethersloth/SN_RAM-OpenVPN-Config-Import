                                                                                                                              <!--

    Add per-tunnel items to ipsec.conf:                                                                                       -->

<!--Moved to prfhandler_ipsec
    <astep      abort="y"
               errmsg="Failed to write ipsec.conf file"
                 name="AppendFormatted2File"
               repeat="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel"
           rptNdxName="RPT_NDX">
     <arg expr="/tmp/ipsec.conf" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text()) > 0)"
                expr="concat('conn ', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text())"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg expr="\n" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text()) > 0)"
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text()) > 0)"
                expr="'type=tunnel'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text()) > 0)"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2satime/text()) > 0)"
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2satime/text()) > 0)"
                expr="concat('keylife=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2satime/text(), 'm')"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2satime/text()) > 0)"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1satime/text()) > 0)"
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1satime/text()) > 0)"
                 expr="concat('ikelifetime=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1satime/text(), 'm')"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1satime/text()) > 0)"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/encmethod/text() = 'psk'" 
        expr="'authby=secret'" 
          rptNdxName="RPT_NDX"
        source="config" />
        
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/encmethod/text() = 'cert'" 
        expr="'authby=rsasig'" 
          rptNdxName="RPT_NDX"
        source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/encmethod/text() = 'cert'" 
        expr="'leftrsasigkey=%cert'" 
          rptNdxName="RPT_NDX"
        source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/encmethod/text() = 'cert'" 
        expr="'leftsendcert=always'" 
          rptNdxName="RPT_NDX"
        source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/encmethod/text() = 'cert'" 
        expr="concat('leftcert=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/lccert/text())"
        rptNdxName="RPT_NDX"
        source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/encmethod/text() = 'cert'" 
        expr="'rightca=%any'" 
        rptNdxName="RPT_NDX"
        source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/encmethod/text() = 'cert'" 
        expr="concat('rightcert=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/rscert/text())"
        rptNdxName="RPT_NDX"
        source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2authtype/text()) > 0)"
        expr="concat('auth=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2authtype/text())"
        rptNdxName="RPT_NDX"
        source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2authtype/text() = 'esp'"
     expr="concat('esp=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2enc/text(), '-', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2auth/text())"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg expr="\n" />


     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2authtype/text() = 'ah'"
     expr="concat('ah=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p2ahauthenc/text())"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg       expr="concat('ike=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1enc/text(), '-', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1auth/text())"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1dhg/text()) > 0 and substring(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1dhg/text(),1,2) != 'dh')"
                expr="concat('-', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1dhg/text())"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1dhg/text()) > 0 and substring(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1dhg/text(),1,2) = 'dh')"
                expr="concat(';', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/p1dhg/text())"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg expr="\n" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"      
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"     
                expr="concat('dpdaction=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text())"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"      
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"      
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpdintvl/text() > 0 and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"
                expr="concat('dpddelay=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpdintvl/text())"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpdintvl/text() > 0 and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpdtimeout/text() > 0 and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpdtimeout/text() > 0 and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"
                expr="concat('dpdtimeout=', /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpdtimeout/text())"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpdtimeout/text() > 0 and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/dpd/text() != 'disable'"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/enable/text() = 'Yes' and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/tunneltype/text() = 'client'"
                expr="'auto=start'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/enable/text() = 'Yes' and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/tunneltype/text() = 'server'"
                expr="'auto=add'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/enable/text() = 'Yes' and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/tunneltype/text() = 'dynamic'"
                expr="'auto=route'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/enable/text() = 'No'"
                expr="'auto=ignore'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/pfs/text() = 'y'"
                expr="'pfs=yes'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/pfs/text() = 'n'"
                expr="'pfs=no'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg expr="\n" />

     <arg expr="\t" />
     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'y'"
                expr="'aggrmode=yes'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'n'"
                expr="'aggrmode=no'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg expr="\n" />

     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text()) > 0)"
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text()) > 0) and /GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/tunneltype/text() = 'client'"
                expr="'keyingtries=%forever'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg dependency="(string-length(/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/name/text()) > 0)"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg expr="\t" />
