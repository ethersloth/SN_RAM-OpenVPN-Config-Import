     <arg expr="\n" />

     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'\t'"                source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'nat_traversal=yes'" source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'\n'"                source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'\t'"                  source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'force_keepalive=yes'" source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'\n'"                  source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'\t'"              source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'keep_alive=6600'" source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'y'" expr="'\n'"              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'n'" expr="'\t'"                  source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'n'" expr="'# nat_traversal=yes'" source="config" />
     <arg dependency="/GAUCfg/vpn/ipsec/natt/text() = 'n'" expr="'\n'"                  source="config" />

     <arg expr="\t" />
     <arg expr="# virtual_private=%v4:10.0.0.0/8,%v4:192.168.0.0/16,%v4:172.16.0.0/12" />
     <arg expr="\n" />
    </astep>

    <astep      abort="y"
                break="pass"
               errmsg="Failed to append to ipsec.conf file."
                 name="AppendFormatted2File"
               repeat="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel"
           rptNdxName="RPT_NDX">

     <arg expr="/tmp/ipsec.conf" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'y'"
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'y'"
                expr="'nhelpers=0'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'y'"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />
    </astep>

    <astep      abort="y"
                break="pass"
               errmsg="Failed to append to ipsec.conf file."
                 name="AppendFormatted2File"
               repeat="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel"
           rptNdxName="RPT_NDX">

     <arg expr="/tmp/ipsec.conf" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'n'"
                expr="'\t'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'n'"
                expr="'nhelpers=0'"
          rptNdxName="RPT_NDX"
              source="config" />

     <arg dependency="/GAUCfg/vpn/ipsec/ipsectunnels/ipsectunnel[RPT_NDX]/aggrmode/text() = 'n'"
                expr="'\n'"
          rptNdxName="RPT_NDX"
              source="config" />
    </astep>

    <astep abort="y" errmsg="Failed to append to ipsec.conf file." name="AppendFormatted2File">

     <arg expr="/tmp/ipsec.conf" />

     <arg expr="\n" />
     <arg expr="#Openswan supports a mode called " />
     <arg expr="quote()" source="config" />
     <arg expr="opportunistic compression" />
     <arg expr="quote()" source="config" />
     <arg expr="\n" />
     <arg expr="#in the way of simple static tunnels. If you are just" />
     <arg expr="\n" />
     <arg expr="#VPN server using Openswan, add the following to disable OE." />
     <arg expr="\n" />
     <arg expr="conn OEself" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="auto=ignore" />
     <arg expr="\n" />
     <arg expr="conn clear" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="auto=ignore" />
     <arg expr="\n" />
     <arg expr="conn private" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="auto=ignore" />
     <arg expr="\n" />
     <arg expr="conn private-or-clear" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="auto=ignore" />
     <arg expr="\n" />
     <arg expr="conn clear-or-private" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="auto=ignore" />
     <arg expr="\n" />
     <arg expr="conn block" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="auto=ignore" />
     <arg expr="\n" />
     <arg expr="conn packetdefault" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="auto=ignore" />
     <arg expr="\n" />
     <arg expr="#end config to disable " />
     <arg expr="quote()" source="config" />
     <arg expr="opportunistic encryption" />
     <arg expr="quote()" source="config" />
     <arg expr="\n" />
     <arg expr="\n" />
     <arg expr="# Add connections here" />
     <arg expr="\n" />
    </astep>
