
<profile>
 <subsystems>
                                                                                                                              <!--
                Networking -> IPSec Tunnels Section

  (Comments re: V2.20 behaviors (taken from cfg_sec.cpp - ApplyVPNSettings() & SaveVPNSettings(), removed)                     -->

  <subsystem file="/home/httpd/jbmconfig/conf/ipsectunnel.prf" name="ipsectunnel">
   <validation>
    <vstep errmsg="Invalid Tunnel Record Set. Must be a well-formed XML document."
             name="ipsectunnels"
             test="string-length(/input/ipsectunnels/text()) > 0" />
   </validation>


   <configuration>
    <cstep errmsg="Unable to save Enable to system configuration file."
              name="enableipsec"
              path="/GAUCfg/vpn/ipsec/enableipsec" />
    <cstep errmsg="Unable to save Nat to system configuration file."
              name="natt"
              path="/GAUCfg/vpn/ipsec/natt" />
    <cstep errmsg="Unable to save Wireless PPP coordination to system configuration file."
              name="wpppconnect"
              path="/GAUCfg/vpn/ipsec/wpppconnect" />
    <cstep errmsg="Unable to save PPPoE coordination to system configuration file."
              name="pppoeconnect"
              path="/GAUCfg/vpn/ipsec/pppoeconnect" />
    <cstep errmsg="Unable to save Dial-up PPP coordination to system configuration file."
              name="pppdialconnect"
              path="/GAUCfg/vpn/ipsec/pppdialconnect" />
    <cstep errmsg="Unable to save Wireless PPP coordination to system configuration file."
              name="wpppdisconnect"
              path="/GAUCfg/vpn/ipsec/wpppdisconnect" />
    <cstep errmsg="Unable to save PPPoE coordination to system configuration file."
              name="pppoedisconnect"
              path="/GAUCfg/vpn/ipsec/pppoedisconnect" />
    <cstep errmsg="Unable to save Dial-up PPP coordination to system configuration file."
              name="pppdialdisconnect"
              path="/GAUCfg/vpn/ipsec/pppdialdisconnect" />

    <cstep errmsg="Unable to save Tunnels to system configuration file."
              name="ipsectunnels" path="/GAUCfg/vpn/ipsec/ipsectunnels"
              type="node" />
   </configuration>


   <action name="Save" successmsg="Operation Succeeded.">

    <astep abort="n" errmsg="Failed to save ipsec configuration" name="SystemCommand">
     <arg expr="'prfhandler_ipsec Save'" source="config" />
    </astep>

                                                                                                                              <!--
    Build ipsec.conf file preamble:                                                                                           -->

