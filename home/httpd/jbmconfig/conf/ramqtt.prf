    <astep      abort="y"
           dependency="/GAUCfg/ramqtt/iodbpoints/NumberOfiodbpoints/text() != '0'"
               errmsg="Failed to append IODB points ramqtt configuration file"
                 name="AppendFormatted2File"
               repeat="/GAUCfg/ramqtt/iodbpoints/iodbpoint"
           rptNdxName="RPT_NDX">

     <arg expr="/tmp/conf.json" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="{" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="concat(quote(), 'type', quote(), ':', quote(), /GAUCfg/ramqtt/iodbpoints/iodbpoint[RPT_NDX]/type/text(), quote(), ',')" rptNdxName="RPT_NDX" source="config" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="concat(quote(), 'register', quote(), ':', quote(), /GAUCfg/ramqtt/iodbpoints/iodbpoint[RPT_NDX]/register/text(), quote())" rptNdxName="RPT_NDX" source="config" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg dependency="/GAUCfg/ramqtt/iodbpoints/NumberOfiodbpoints/text() != 'RPT_NDX'"
                expr="'},'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg dependency="/GAUCfg/ramqtt/iodbpoints/NumberOfiodbpoints/text() = 'RPT_NDX'"
                expr="'}'"
          rptNdxName="RPT_NDX"
              source="config" />
     <arg expr="\n" />
    </astep>

    <astep  abort="y" errmsg="Failed to write RAMQTT Configuration file" name="AppendFormatted2File">
     <arg expr="/tmp/conf.json" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="]" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="}" />
     <arg expr="\n" />
     <arg expr="}" />
     <arg expr="\n" />
    </astep>

    <astep abort="y" errmsg="Failed to move RAMQTT conf.json file to /etc/ramqtt/ directory." name="SystemCommand">
     <arg expr="mkdir -p /etc/ramqtt/; mv -f /tmp/conf.json /etc/ramqtt/conf.json" />
    </astep>

    <astep abort="n" errmsg="Failed to stop RAMQTT service" name="SystemCommand">
     <arg dependency="/GAUCfg/ramqtt/enable/text() = 'n'" expr="'chkconfig ramqtt off'" source="config"/>
    </astep>

    <astep abort="y" errmsg="Failed to start RAMQTT service" name="SystemCommand">
     <arg dependency="/GAUCfg/ramqtt/enable/text() = 'y'" expr="'chkconfig ramqtt on'" source="config"/>
    </astep>
Moved to prfhandler_ramqtt-->

    <astep abort="y" errmsg="Failed to save ramqtt configuration" name="SystemCommand">
     <arg expr="'prfhandler_ramqtt Save'" source="config" />
    </astep>

   </action>

   <action name="Apply" successmsg="RAMQTT settings applied.">

<!--Moved to prfhandler_ramqtt
    <pre subsystem="ramqtt" action="Save" />

    <astep abort="y" errmsg="Failed to stop RAMQTT service" name="SystemCommand">
     <arg dependency="/GAUCfg/ramqtt/enable/text() = 'n'" expr="'service ramqtt stop'" source="config"/>
    </astep>

    <astep abort="y" errmsg="Failed to start RAMQTT service" name="SystemCommand">
     <arg dependency="/GAUCfg/ramqtt/enable/text() = 'y'" expr="'service ramqtt restart'" source="config"/>
    </astep>
Moved to prfhandler_ramqtt-->

    <astep abort="y" errmsg="Failed to apply ramqtt configuration" name="SystemCommand">
     <arg expr="'prfhandler_ramqtt Apply'" source="config" />
    </astep>

   </action>

  </subsystem>
 </subsystems>
</profile>
