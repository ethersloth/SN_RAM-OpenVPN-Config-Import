     <arg expr="\t" />
     <arg expr="concat(quote(), 'iodbScanRate', quote(), ':', quote(), /GAUCfg/ramqtt/scanrate/text(), quote(), ',')" source="config" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="concat(quote(), 'tags', quote(), ':')" source="config" />
     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="[" />
     <arg expr="\n" />
