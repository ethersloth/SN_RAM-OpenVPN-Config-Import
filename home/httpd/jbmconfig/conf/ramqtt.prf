     <arg expr="\n" />
     <arg expr="\t" />
     <arg expr="\t" />
     <arg expr="concat(quote(), 'devKey', quote(), ':', quote(), '/etc/ramqtt/certs/', /GAUCfg/ramqtt/devkey/text(), quote(), ',')" source="config" />
     <arg expr="\n" />
     <arg expr="\t" />
