-->
    <cstep errmsg="Cannot save UDP Broadcast settings to configuration file"
             name="udprules"
             path="/GAUCfg/serialip/udprules" type="node" />

   </configuration>

   <action name="Save" successmsg="Save Operation Succeeded.">
       <!-- Start writing the gwlnx configuration file. -->

<!--Moved to prfhandler_serialip
       <astep errmsg="Failed to write the gwlnx configuration file." name="WriteFormattedFile" abort="y">
           <arg expr="concat('/tmp/', /GAUCfg/serialip/sockettype/text(), '.xml')" source="config" />
       </astep>

       <astep abort="y" errmsg="Failed to write the XML headers for configuration file." name="AppendFormatted2File">
           <arg expr="concat('/tmp/', /GAUCfg/serialip/sockettype/text(), '.xml')"  source="config" />
           <arg expr="concat('<?xml version=', tick(), '1.0', tick(), ' encoding=', tick(), 'UTF-8', tick(), '?>')"  source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<!DOCTYPE UnitCfg SYSTEM ', tick(), 'jbmcfg.dtd', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<UnitCfg unitdescr = ', tick(), /GAUCfg/serialip/description/text(), tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="'<TransferInfo></TransferInfo>'" source="config" />
           <arg expr="\n" />
           <arg expr="'<PortCfg>'" source="config" />
           <arg expr="\n" />
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'udp' or /GAUCfg/serialip/sockettype/text() = 'tcps' or /GAUCfg/serialip/sockettype/text() = 'tcpc'" expr="'<MaxPorts>2</MaxPorts>'" source="config" />
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'tcpcbrdcast'" expr="'<MaxPorts>3</MaxPorts>'" source="config" />
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'udpbrdcast'" expr="'<MaxPorts>7</MaxPorts>'" source="config" />
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'tcp2way' and /GAUCfg/serialip/dtrdial/text() = 'no'" expr="'<MaxPorts>4</MaxPorts>'" source="config" />
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'tcp2way' and /GAUCfg/serialip/dtrdial/text() = 'yes'" expr="'<MaxPorts>5</MaxPorts>'" source="config" />
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'tcpcbrdcasttraffact'" expr="'<MaxPorts>23</MaxPorts>'" source="config" />
           <arg expr="\n" />
           <arg expr="\n" />
       </astep>

       <astep abort="y" errmsg="Failed to write the Comm Port Manager configuration file." name="AppendFormatted2File">
           <arg expr="concat('/tmp/', /GAUCfg/serialip/sockettype/text(), '.xml')"  source="config" />
           <arg expr="concat('<CommPortMngr:CommPortManagerCfg portdescr=', tick(), 'ComMgr', tick(), ' portnumber=', tick(), '1', tick(), ' protoID=', tick(), '8091', tick(), ' xmlns:CommPortMngr=', tick(), 'Commmanger', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="'<UseCycladesRAS>no</UseCycladesRAS>'" source="config"/>
           <arg expr="\n" />
           <arg dependency="/GAUCfg/serialip/dnis/text() = 'yes'"
                      expr="concat('<UseDNISRouting DNIStablefilename=', tick(), 'dtmftty.conf', tick(), '>', /GAUCfg/serialip/dnis/text(), '</UseDNISRouting>')" source="config"/>
           <arg dependency="/GAUCfg/serialip/dnis/text() = 'no' and /GAUCfg/serialip/dialip/text() = 'yes'"
                      expr="concat('<UseDNISRouting DNIStablefilename=', tick(), 'dialip.conf', tick(), '>', /GAUCfg/serialip/dialip/text(), '</UseDNISRouting>')" source="config"/>
           <arg dependency="/GAUCfg/serialip/dnis/text() = 'no' and /GAUCfg/serialip/dialip/text() = 'no'"
                      expr="concat('<UseDNISRouting DNIStablefilename=', tick(), tick(), '>', /GAUCfg/serialip/dnis/text(), '</UseDNISRouting>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<DoCallReporting callreportfilename=', tick(), 'CallReport', tick(), '>', /GAUCfg/serialip/callreport/text(), '</DoCallReporting>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<DoCallerIDFilter calleridfilterfilename=', tick(), tick(), '>no</DoCallerIDFilter>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<MaxSubaddrs>1</MaxSubaddrs>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<CommPortMngr:Subaddr subaddress=', tick(), '1', tick(), '>')" source="config"/>
           <arg expr="\n" />
           <arg dependency="/GAUCfg/serialip/intf/text() = 'ttyS1'"
                expr="'<CommPortID>2</CommPortID>'" source="config"/>
           <arg dependency="/GAUCfg/serialip/intf/text() = 'ttyS5'"
                expr="'<CommPortID>6</CommPortID>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<LineSpeed>', /GAUCfg/serialip/linespeed/text(), '</LineSpeed>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<Parity>', /GAUCfg/serialip/parity/text(), '</Parity>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<WordLength>', /GAUCfg/serialip/wordlength/text(), '</WordLength>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<StopBit>', /GAUCfg/serialip/stopbit/text(), '</StopBit>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<IndActivate>', /GAUCfg/serialip/indactive/text(), '</IndActivate>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<DialString></DialString>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<MaxConnectAttempts>0</MaxConnectAttempts>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<ConnectionType>', /GAUCfg/serialip/connectiontype/text(), '</ConnectionType>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<APHCfg>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<EORAPHCfg:APHConfig aphID=', tick(), 'ff74', tick(), ' xmlns:EORAPHCfg=', tick(), 'EORAPH', tick(), '>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<EORString></EORString>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<StripEOR>no</StripEOR>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<NmbrTrailBytesAfterEOR>0</NmbrTrailBytesAfterEOR>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<UseStartDataChar>no</UseStartDataChar>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<StartDataChar>00</StartDataChar>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<InterCharTimeout>', /GAUCfg/serialip/interchartimeout/text(), '</InterCharTimeout>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<UseTimerOnly>', /GAUCfg/serialip/usetimer/text(), '</UseTimerOnly>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<MaxBufSize>', /GAUCfg/serialip/maxbufsize/text(), '</MaxBufSize>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<MaxTxBeforeReset>', /GAUCfg/serialip/missedpoll/text(), '</MaxTxBeforeReset>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<DiscardRXDataBeforeTX>no</DiscardRXDataBeforeTX>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<Spoof1stENQ>no</Spoof1stENQ>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<SendEotOnRmtDisc>no</SendEotOnRmtDisc>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<CaptureLastPacket>yes</CaptureLastPacket>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'</EORAPHCfg:APHConfig>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'</APHCfg>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<IdleRXTimeout>0</IdleRXTimeout>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<IdleTXTimeout>0</IdleTXTimeout>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<ModemInitStrings>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<List>'" source="config"/>
           <arg expr="\n" />
           <arg dependency="(string-length(/GAUCfg/serialip/atcommand/text()) = 0 )"
                expr="'<ListCount>0</ListCount>'" source="config"/>
           <arg dependency="(string-length(/GAUCfg/serialip/atcommand/text()) > 0 )"
                expr="'<ListCount>1</ListCount>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<ListEntry listentry=', tick(), '1', tick(), '>', /GAUCfg/serialip/atcommand/text(), '</ListEntry>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'</List>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'</ModemInitStrings>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<UseDTRDial>', /GAUCfg/serialip/dtrdial/text(), '</UseDTRDial>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<UseISDNDial>no</UseISDNDial>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<UseIgnoreDTR>', /GAUCfg/serialip/ignoredtr/text(), '</UseIgnoreDTR>')" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<ignoreRingOut>', /GAUCfg/serialip/ignoreringout/text(), '</ignoreRingOut>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<DCDConnectDly>0</DCDConnectDly>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<SwitchBaudRate>no</SwitchBaudRate>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<AlternateBaudRate>auto</AlternateBaudRate>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<SwitchThreshold>0</SwitchThreshold>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<RingTimer>0</RingTimer>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<CoBypassWhenExtLinePresent>no</CoBypassWhenExtLinePresent>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<CoWaitForUnmatchedPhoneNum>0</CoWaitForUnmatchedPhoneNum>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<EmulConnectMsgDelay>0</EmulConnectMsgDelay>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<HdwFlowCtrl>', /GAUCfg/serialip/flowctrl/text(), '</HdwFlowCtrl>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<FlushDataOpt>allchanges</FlushDataOpt>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'</CommPortMngr:Subaddr>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'</CommPortMngr:CommPortManagerCfg>'" source="config"/>
           <arg expr="\n" />
       </astep>

       <astep abort="y"
             errmsg="Failed to write the UDP Port Configuration file."
         dependency="/GAUCfg/serialip/sockettype/text() = 'udp'"
               name="AppendFormatted2File">
           <arg expr="concat('/tmp/', /GAUCfg/serialip/sockettype/text(), '.xml')"  source="config" />
           <arg expr="concat('<UDPServer:UDPServerCfg portdescr=', tick(), 'UDPServer', tick(), ' portnumber=', tick(), '2', tick(), ' protoID=', tick(), '0311', tick(), ' xmlns:UDPServer=', tick(), 'udpserver', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="'<MaxAddrs>1</MaxAddrs>'" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<UDPServer:Addr address=', tick(), '1', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<IPPort>', /GAUCfg/serialip/peerport/text(), '</IPPort>')" source="config" />
           <arg expr="\n" />
           <arg expr="'<EndToEnd>no</EndToEnd>'" source="config" />
           <arg expr="\n" />
           <arg expr="'<MaxSubaddrs>1</MaxSubaddrs>'" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<UDPServer:Subaddr subaddress=', tick(), '1', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<IPAddr>', /GAUCfg/serialip/peerip/text(), '</IPAddr>')" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<IndActivate>', 'yes', '</IndActivate>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<WaitForRsp>no</WaitForRsp>'" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<ClientIPPort>', /GAUCfg/serialip/clientipport/text(), '</ClientIPPort>')" source="config"/>
           <arg expr="\n" />
           <arg expr="'<HeaderCfg></HeaderCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="'</UDPServer:Subaddr>'" source="config" />
           <arg expr="\n" />
           <arg expr="'</UDPServer:Addr>'" source="config" />
           <arg expr="\n" />
           <arg expr="'<UDPServer:PortHardwareCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="'<IPAddr>0.0.0.0</IPAddr>'" source="config" />
           <arg expr="\n" />
           <arg dependency="/GAUCfg/serialip/srcintf/text() != 'None'"
                expr="concat('<IntfFileCfg>', /GAUCfg/serialip/srcintf/text(), '</IntfFileCfg>')" source="config" />
           <arg dependency="/GAUCfg/serialip/srcintf/text() = 'None'"
                expr="'<IntfFileCfg></IntfFileCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="'</UDPServer:PortHardwareCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="'</UDPServer:UDPServerCfg>'" source="config" />
           <arg expr="\n" />
       </astep>

       <astep abort="y"
             errmsg="Failed to write the TCP Server Port Configuration file."
         dependency="/GAUCfg/serialip/sockettype/text() = 'tcps' or /GAUCfg/serialip/sockettype/text() = 'tcp2way'"
               name="AppendFormatted2File">
           <arg expr="concat('/tmp/', /GAUCfg/serialip/sockettype/text(), '.xml')"  source="config" />
           <arg expr="concat('<TCPServer:TCPServerCfg portdescr=', tick(), 'TCPServer', tick(), ' portnumber=', tick(), '2', tick(), ' protoID=', tick(), '0431', tick(), ' xmlns:TCPServer=', tick(), 'tcpclserver', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="'<MaxAddrs>1</MaxAddrs>'" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<TCPServer:Addr address=', tick(), '1', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<IPPort>', /GAUCfg/serialip/listenport/text(), '</IPPort>')" source="config" />
           <arg expr="\n" />
           <arg expr="'<CoordinatedListener>no</CoordinatedListener>'" source="config" />
           <arg expr="\n" />
           <arg expr="'<MaxSubaddrs>1</MaxSubaddrs>'" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<TCPServer:Subaddr subaddress=', tick(), '1', tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<IPAddr>', /GAUCfg/serialip/listenip/text(), '</IPAddr>')" source="config" />
           <arg expr="\n" />
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'tcps'"
                expr="concat('<IndActivate>', /GAUCfg/serialip/tcpindactive/text(), '</IndActivate>')" source="config"/>
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'tcp2way' and /GAUCfg/serialip/dtrdial/text() = 'no'"
                expr="'<IndActivate>no</IndActivate>'" source="config"/>
           <arg dependency="/GAUCfg/serialip/sockettype/text() = 'tcp2way' and /GAUCfg/serialip/dtrdial/text() = 'yes'"
                expr="'<IndActivate>yes</IndActivate>'" source="config"/>
           <arg expr="\n" />
           <arg expr="concat('<AllowPeerReattach>', /GAUCfg/serialip/allowpeerreattach/text(), '</AllowPeerReattach>')" source="config" />
           <arg expr="\n" />
           <arg expr="'<APHCfg></APHCfg>'" source="config"/>
           <arg expr="\n" />
           <arg expr="'<HeaderCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="concat('<MsgLenHeaderCfg msghdrtype=', tick(), /GAUCfg/serialip/headers/text(), tick(), '>')" source="config" />
           <arg expr="\n" />
           <arg expr="'</MsgLenHeaderCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="'</HeaderCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="'</TCPServer:Subaddr>'" source="config" />
           <arg expr="\n" />
           <arg expr="'</TCPServer:Addr>'" source="config" />
           <arg expr="\n" />
           <arg expr="'<TCPServer:PortHardwareCfg>'" source="config" />
           <arg expr="\n" />
           <arg expr="'<IPAddr>0.0.0.0</IPAddr>'" source="config" />
