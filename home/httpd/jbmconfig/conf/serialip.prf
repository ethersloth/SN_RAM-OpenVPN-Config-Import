
<profile>
 <subsystems>

                <!-- Advanced -> Serial IP Interface Section -->

  <subsystem file="/home/httpd/jbmconfig/conf/serialip.prf" name="serialip">

   <validation>
    <vstep errmsg="Invalid Enable value. Must be 'Yes' or 'No'."
             name="enable"
             test="/input/enable/text() = 'no'  or
                   /input/enable/text() = 'yes'"   />
   </validation>

   <configuration>
    <cstep errmsg="Unable to save Enable value to system configuration file."
             name="enable"
             path="/GAUCfg/serialip/enable" />

    <cstep errmsg="Unable to save Config Description to system configuration file."
             name="description"
             path="/GAUCfg/serialip/description" />

    <cstep errmsg="Unable to save Advance Setup Option to system configuration file."
             name="advancesetup"
             path="/GAUCfg/serialip/advancesetup" />

    <cstep errmsg="Unable to save DNIS Routing Option to system configuration file."
             name="dnis"
             path="/GAUCfg/serialip/dnis" />

    <cstep errmsg="Unable to save Call Reporting Option to system configuration file."
             name="callreport"
             path="/GAUCfg/serialip/callreport" />

    <cstep errmsg="Unable to save Call Reporting Filename to system configuration file."
             name="callreportfilename"
             path="/GAUCfg/serialip/callreportfilename" />

<!-- Start of CommPort Manager options -->
    <cstep errmsg="Unable to save Serial Interface value to system configuration file."
             name="intf"
             path="/GAUCfg/serialip/intf" />

    <cstep errmsg="Unable to save AT Command value to system configuration file."
             name="atcommand"
             path="/GAUCfg/serialip/atcommand" />

    <cstep errmsg="Unable to save Line Speed value to system configuration file."
             name="linespeed"
             path="/GAUCfg/serialip/linespeed" />

    <cstep errmsg="Unable to save Word Length value to system configuration file."
             name="wordlength"
             path="/GAUCfg/serialip/wordlength" />

    <cstep errmsg="Unable to save Independent Activation value to system configuration file."
             name="indactive"
             path="/GAUCfg/serialip/indactive" />

    <cstep errmsg="Unable to save Parity value to system configuration file."
             name="parity"
             path="/GAUCfg/serialip/parity" />

    <cstep errmsg="Unable to save Stop Bit value to system configuration file."
             name="stopbit"
             path="/GAUCfg/serialip/stopbit" />

    <cstep errmsg="Unable to save DTR Dial Option value to system configuration file."
             name="dtrdial"
             path="/GAUCfg/serialip/dtrdial" />

    <cstep errmsg="Unable to save Dial IP Option value to system configuration file."
             name="dialip"
             path="/GAUCfg/serialip/dialip" />

    <cstep errmsg="Unable to save Dial IP RING Option value to system configuration file."
             name="ignoreringout"
             path="/GAUCfg/serialip/ignoreringout" />

    <cstep errmsg="Unable to save Ignore DTR Option value to system configuration file."
             name="ignoredtr"
             path="/GAUCfg/serialip/ignoredtr" />

    <cstep errmsg="Unable to save ConnectionType Option to system configuration file."
             name="connectiontype"
             path="/GAUCfg/serialip/connectiontype" />

    <cstep errmsg="Unable to save Inter Character Timeout value to system configuration file."
             name="interchartimeout"
             path="/GAUCfg/serialip/interchartimeout" />

    <cstep errmsg="Unable to save Use Timer Only option value to system configuration file."
             name="usetimer"
             path="/GAUCfg/serialip/usetimer" />

    <cstep errmsg="Unable to save EOM character(s) to system configuration file."
             name="eomstring"
             path="/GAUCfg/serialip/eomstring" />

    <cstep errmsg="Unable to save strip EOM character option to system configuration file."
             name="stripeom"
             path="/GAUCfg/serialip/stripeom" />

    <cstep errmsg="Unable to save Max Buffer Size value to system configuration file."
             name="maxbufsize"
             path="/GAUCfg/serialip/maxbufsize" />

    <cstep errmsg="Unable to save Hardware Flow Control value to system configuration file."
             name="flowctrl"
             path="/GAUCfg/serialip/flowctrl" />

    <cstep errmsg="Unable to save Max TX Packets Before Reset value to system configuration file."
             name="missedpoll"
             path="/GAUCfg/serialip/missedpoll" />

<!-- Start of TCP/UDP socket type options -->
    <cstep errmsg="Unable to save TCP Independent Activation Option value to system configuration file."
             name="tcpindactive"
             path="/GAUCfg/serialip/tcpindactive" />

    <cstep errmsg="Unable to save Socket Type to system configuration file."
             name="sockettype"
             path="/GAUCfg/serialip/sockettype" />

    <cstep errmsg="Unable to save Host IP Address to system configuration file."
             name="hostip"
             path="/GAUCfg/serialip/hostip" />

    <cstep errmsg="Unable to save Host IP Port Address to system configuration file."
             name="hostport"
             path="/GAUCfg/serialip/hostport" />

    <cstep errmsg="Unable to save Client Source Port Address to system configuration file."
             name="sourceport"
             path="/GAUCfg/serialip/sourceport" />

    <cstep errmsg="Unable to save TCP Headers to system configuration file."
             name="headers"
             path="/GAUCfg/serialip/headers" />

    <cstep errmsg="Unable to save Destination Config File to system configuration file."
             name="destcfg"
             path="/GAUCfg/serialip/destcfg" />

    <cstep errmsg="Unable to save Allow Peer Reattach Option to system configuration file."
             name="allowpeerreattach"
             path="/GAUCfg/serialip/allowpeerreattach" />

    <cstep errmsg="Unable to save Server Listening IP Address to system configuration file."
             name="listenip"
             path="/GAUCfg/serialip/listenip" />

    <cstep errmsg="Unable to save Server Listening Port Address to system configuration file."
             name="listenport"
             path="/GAUCfg/serialip/listenport" />

    <cstep errmsg="Unable to save Server Peer IP Address to system configuration file."
             name="peerip"
             path="/GAUCfg/serialip/peerip" />

    <cstep errmsg="Unable to save Server Peer Port Address to system configuration file."
             name="peerport"
             path="/GAUCfg/serialip/peerport" />

    <cstep errmsg="Unable to save Client IP Port Address to system configuration file."
             name="clientipport"
             path="/GAUCfg/serialip/clientipport" />

    <cstep errmsg="Unable to save UDP Source Interface to system configuration file."
             name="srcintf"
             path="/GAUCfg/serialip/srcintf" />
