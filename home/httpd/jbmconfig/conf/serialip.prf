    <cstep errmsg="Unable to save Second Server Peer IP Address to system configuration file."
             name="peerip2"
             path="/GAUCfg/serialip/peerip2" />

    <cstep errmsg="Unable to save Second Server Peer Port Address to system configuration file."
             name="peerport2"
