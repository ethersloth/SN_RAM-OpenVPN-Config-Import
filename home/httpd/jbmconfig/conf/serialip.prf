             path="/GAUCfg/serialip/peerport3" />

    <cstep errmsg="Unable to save Third Client IP Port Address to system configuration file."
             name="clientipport3"
             path="/GAUCfg/serialip/clientipport3" />

    <cstep errmsg="Unable to save Fourth Server Peer IP Address to system configuration file."
             name="peerip4"
             path="/GAUCfg/serialip/peerip4" />

    <cstep errmsg="Unable to save Fourth Server Peer Port Address to system configuration file."
             name="peerport4"
             path="/GAUCfg/serialip/peerport4" />

    <cstep errmsg="Unable to save Fourth Client IP Port Address to system configuration file."
             name="clientipport4"
             path="/GAUCfg/serialip/clientipport4" />

    <cstep errmsg="Unable to save Fifth Server Peer IP Address to system configuration file."
             name="peerip5"
             path="/GAUCfg/serialip/peerip5" />

    <cstep errmsg="Unable to save Fifth Server Peer Port Address to system configuration file."
             name="peerport5"
             path="/GAUCfg/serialip/peerport5" />

    <cstep errmsg="Unable to save Fifth Client IP Port Address to system configuration file."
