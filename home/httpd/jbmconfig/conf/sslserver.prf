Moved to prfhandler_sslserver-->

   </action>

   <action name="Apply" successmsg="SSL Server configuration applied.">

    <astep abort="y" errmsg="Failed to apply sslserver configuration" name="SystemCommand">
     <arg expr="'prfhandler_sslserver Apply'" source="config" />
    </astep>

