     <arg       expr="concat('ln -sf /etc/jbm/certificates/', /GAUCfg/certmgr/certificates/certificate[RPT_NDX]/file/text(), ' /etc/openvpn/.')"
          dependency="/GAUCfg/certmgr/certificates/certificate[RPT_NDX]/type/text() = 'sslvpn'"
          rptNdxName="RPT_NDX"
              source="config"  />

     <arg       expr="concat('ln -sf /etc/jbm/certificates/', /GAUCfg/certmgr/certificates/certificate[RPT_NDX]/file/text(), ' /etc/ramqtt/certs/.')"
          dependency="/GAUCfg/certmgr/certificates/certificate[RPT_NDX]/type/text() = 'ramqttcert'"
          rptNdxName="RPT_NDX"
              source="config"  />

     <arg       expr="concat('ln -sf /etc/jbm/certificates/', /GAUCfg/certmgr/certificates/certificate[RPT_NDX]/file/text(), ' /etc/ramqtt/certs/.')"
          dependency="/GAUCfg/certmgr/certificates/certificate[RPT_NDX]/type/text() = 'ramqttkey'"
          rptNdxName="RPT_NDX"
              source="config"  />

     <arg       expr="concat('ln -sf /etc/jbm/certificates/', /GAUCfg/certmgr/certificates/certificate[RPT_NDX]/file/text(), ' /etc/ramqtt/certs/.')"
          dependency="/GAUCfg/certmgr/certificates/certificate[RPT_NDX]/type/text() = 'ramqttca'"
          rptNdxName="RPT_NDX"
              source="config"  />

    </astep>
Moved to prfhandler_certmgr-->

    <astep abort="y" errmsg="Failed to save certmgr configuration" name="SystemCommand">
     <arg expr="'prfhandler_certmgr Save'" source="config" />
    </astep>

   </action>

   <action name="Apply" successmsg="Operation Succeeded.">

<!--Moved to prfhandler_certmgr
    <pre subsystem="certmgr" action="Save" />

    <astep abort="n" errmsg="Failed to clean Certificate repository" name="SystemCommand" >
     <arg expr="/home/httpd/jbmconfig/bin/cleancertdir" />
    </astep>
Moved to prfhandler_certmgr-->

    <astep abort="y" errmsg="Failed to apply certmgr configuration" name="SystemCommand">
     <arg expr="'prfhandler_certmgr Apply'" source="config" />
    </astep>

   </action>

  </subsystem>
 </subsystems>
</profile>
