Moved to prfhandler_sslclient-->

   </action>

   <action name="Apply" successmsg="SSL Client configuration applied.">
    <astep errmsg="Failed to apply SSL Client configuration." name="SystemCommand" abort="y">
    </astep>

    <astep abort="y" errmsg="Failed to apply sslclient configuration" name="SystemCommand">
     <arg expr="'prfhandler_sslclient Apply'" source="config" />
    </astep>

