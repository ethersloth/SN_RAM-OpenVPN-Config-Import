    <astep  abort="y"
           errmsg="Failed to append per/server config info to DHCP configuration file"
             name="AppendFormatted2File">

     <arg expr="/tmp/dhcpd.conf" />

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="concat('subnet ', /GAUCfg/dhcp/dhcpservers/eth0/subnet/text(), ' netmask ', /GAUCfg/eth0/netmask/text(), ' {')"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\n'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\t'"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'# The range of IPs for this server to give out'"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\n'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\t'"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="concat('range ', /GAUCfg/dhcp/dhcpservers/eth0/saddr/text(), ' ', /GAUCfg/dhcp/dhcpservers/eth0/eaddr/text(), ';')"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\n'"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\n'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\t'"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'# The broadcast IP of the network'"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\n'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
                expr="'\t'"
              source="config" />
     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes'"
