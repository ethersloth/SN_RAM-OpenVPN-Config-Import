     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes' and /GAUCfg/dhcp/dhcpservers/eth0/eth0defaultgateway/text() = 'Yes'"
                expr="'\n'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/eth0defaultgateway/text() = 'Yes' and /GAUCfg/dhcp/weisdns/text() = 'y'"
