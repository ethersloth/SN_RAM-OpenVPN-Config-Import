    <astep  abort="y"
           errmsg="Failed to append Distributed DHCP Leases info to DHCP configuration file"
             name="AppendFormatted2File">

     <arg expr="/tmp/dhcpd.conf" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\n'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'# Distribute DHCP Leases Based on MAC Address'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\n'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\n'"
              source="config" />
    </astep>

    <astep      abort="y"                                                                                                        
               errmsg="Failed to append to dhcpd.conf file."                                                                     
                 name="AppendFormatted2File"                                                                                     
               repeat="/GAUCfg/dhcp/macs/mac"                                                               
           rptNdxName="RPT_NDX">                                                                                                 
                                                                                                                                 
     <arg expr="/tmp/dhcpd.conf" />                                                                                              

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="concat('host username', RPT_NDX, ' {')"
          rptNdxName="RPT_NDX"                
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\n'"
          rptNdxName="RPT_NDX"                
              source="config" />
              
     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\t'"
          rptNdxName="RPT_NDX"                
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="concat('hardware ethernet ', /GAUCfg/dhcp/macs/mac[RPT_NDX]/macaddr/text(), ';')"
          rptNdxName="RPT_NDX"                
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\n'"
          rptNdxName="RPT_NDX"                
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\t'"
          rptNdxName="RPT_NDX"                
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="concat('fixed-address ', /GAUCfg/dhcp/macs/mac[RPT_NDX]/macipaddr/text(), ';')"
          rptNdxName="RPT_NDX"                
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\n'"
          rptNdxName="RPT_NDX"                
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'}'"
              source="config" />

     <arg dependency="/GAUCfg/dhcp/macs/NumberOfmacs/text() != '0'"
                expr="'\n'"
          rptNdxName="RPT_NDX"                
              source="config" />
    </astep>

    <astep abort="y" errmsg="Failed to move dhcpd.conf" name="SystemCommand">
     <arg expr="mv -f /tmp/dhcpd.conf /etc/dhcpd/dhcpd.conf" />
    </astep>

    <astep abort="n" name="SystemCommand">

     <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'No' and /GAUCfg/dhcp/dhcpservers/eth1/enable/text() = 'No' and /GAUCfg/dhcp/dhcpservers/wifi/enable/text() = 'No' and /GAUCfg/dhcp/dhcpservers/usb0/enable/text() = 'No'"
                expr="'chkconfig dhcpd off'"
              source="config" />
    </astep>

    <astep abort="n" errmsg="DHCP cannot be enabled" name="SystemCommand">

      <arg dependency="/GAUCfg/dhcp/dhcpservers/eth0/enable/text() = 'Yes' or /GAUCfg/dhcp/dhcpservers/eth1/enable/text() = 'Yes' or /GAUCfg/dhcp/dhcpservers/wifi/enable/text() = 'Yes' or /GAUCfg/dhcp/dhcpservers/usb0/enable/text() = 'Yes'"
                 expr="'chkconfig dhcpd on'"
               source="config" />
    </astep>
Moved to prfhandler_dhcpserver-->

   </action>

   <action name="Apply" successmsg="DHCP Server settings applied.">

    <astep abort="y" errmsg="Failed to apply dhcpserver configuration" name="SystemCommand">
     <arg expr="'prfhandler_dhcpserver Apply'" source="config" />
    </astep>

