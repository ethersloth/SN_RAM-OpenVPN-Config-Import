     <arg dependency="(/GAUCfg/dhcp/weisdns/text() = 'n' and string-length(/GAUCfg/dhcp/dns1/text()) = 0)" expr="'yourdnsip(, ...)'"             source="config" />
     <arg dependency="(/GAUCfg/dhcp/weisdns/text() = 'n' and string-length(/GAUCfg/dhcp/dns1/text()) = 0)" expr="quote()"                        source="config" />

     <arg dependency="(/GAUCfg/dhcp/weisdns/text() = 'n' and string-length(/GAUCfg/dhcp/dns1/text()) > 0)" expr="'option domain-name-servers '"  source="config" />
     <arg dependency="(/GAUCfg/dhcp/weisdns/text() = 'n' and string-length(/GAUCfg/dhcp/dns1/text()) > 0)" expr="/GAUCfg/dhcp/dns1/text()"       source="config" />
     <arg dependency="(/GAUCfg/dhcp/weisdns/text() = 'n' and string-length(/GAUCfg/dhcp/dns2/text()) > 0)" expr="', '"                           source="config" />
     <arg dependency="(/GAUCfg/dhcp/weisdns/text() = 'n' and string-length(/GAUCfg/dhcp/dns2/text()) > 0)" expr="/GAUCfg/dhcp/dns2/text()"       source="config" />
     <arg dependency="(/GAUCfg/dhcp/weisdns/text() = 'n' and string-length(/GAUCfg/dhcp/dns1/text()) > 0)" expr="';'"                            source="config" />

     <arg expr="\n" />

     <arg dependency="(string-length(/GAUCfg/dhcp/deflease/text()) > 0)"
                expr="'#optional default lease time (in seconds)'"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/dhcp/deflease/text()) > 0)"
                expr="'\n'"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/dhcp/deflease/text()) > 0)"
                expr="'default-lease-time '"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/dhcp/deflease/text()) > 0)"
                expr="/GAUCfg/dhcp/deflease/text()"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/dhcp/deflease/text()) > 0)"
                expr="';'"
              source="config" />

     <arg dependency="(string-length(/GAUCfg/dhcp/deflease/text()) > 0)"
